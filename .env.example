# ApnaKhata — environment template. Copy to .env for local (non-Docker) runs;
# docker-compose.yml sets these for the containers directly.

# --- API gateway (backend) ---
DATABASE_URL=postgres://apnakhata:apnakhata@localhost:5432/apnakhata
PORT=8080
APNAKHATA_API_KEY=demo-key
# CORS origin for the web UI; '*' for local, set to the deployed origin in prod
APNAKHATA_CORS_ORIGIN=*
# Ed25519 PKCS#8 PEM for signing Credit Passports. Omit for an ephemeral dev
# key (passports won't verify across restarts).
# APNAKHATA_PASSPORT_KEY=

# --- Worker ---
TZ=Asia/Kolkata

# --- Web (build-time, read by Vite) ---
# Host-perspective API URL the browser calls. Leave empty to run the web UI in
# standalone demo mode with no backend.
VITE_API_URL=http://localhost:8080
VITE_API_KEY=demo-key
VITE_DEMO_USER_ID=22222222-2222-2222-2222-222222222222
